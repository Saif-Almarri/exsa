        "light": "#16a34a",
        "dark": "#22c55e"
      },
      "successHover": {
        "name": "Success hover state",
        "css": "--color-success-hover",
        "type": "color",
        "light": "#15803d",
        "dark": "#16a34a"
      },
      "danger": {
        "name": "Error / destructive actions",
