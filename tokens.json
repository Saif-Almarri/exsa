        "type": "color",
        "light": "#f4f4f4",
        "dark": "#bbbbbb20"
      },
      "scrollbar": {
        "name": "Scrollbar thumb color",
        "css": "--color-scrollbar",
        "type": "color",
        "light": "#cacae8",
        "dark": "#555555"
      },
      "table": {
        "name": "Table accent color",
        "css": "--color-table",
        "type": "color",
        "light": "#118bee",
        "dark": "#0097fc"
      },

      "success": {
        "name": "Success / green states",
        "css": "--color-success",
